# ============================================
# Backend Environment Variables (Local Dev)
# ============================================
#
# This file is only for local development (without Docker).
#
# For Docker: Define variables in root .env instead
# See README.md for setup instructions.
# ============================================

# Server Configuration
# PORT=3000
# NODE_ENV=development

# Auth0 Configuration
# AUTH0_DOMAIN=your-auth0-domain.auth0.com
# AUTH0_CLIENT_ID=your-auth0-client-id
# AUTH0_CLIENT_SECRET=your-auth0-client-secret

# Production Frontend URL
# For CORS and invitation links in production deployments
# Leave blank for local dev (defaults to http://localhost:5173)
# PUBLIC_FRONTEND_URL=https://app.example.com
