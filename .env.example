# ============================================
# Root Environment Variables for Docker
# ============================================
#
# When using Docker Compose, define all variables here.
# Docker automatically loads this file and passes variables to containers.
#
# For local development (without Docker):
# - Frontend: Create client/.env.local
# - Backend: Create server/.env
#
# See README.md for detailed setup instructions.
# ============================================

# ====== Required: Auth0 Configuration ======
# Create these at https://auth0.com
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# ====== Optional: Auth0 API Audience ======
# Leave blank for basic OIDC login without API audience validation
AUTH0_AUDIENCE=

# ====== Optional: Public URLs (Production) ======
# Set these for production deployments to override internal localhost URLs
# Frontend uses PUBLIC_BACKEND_URL for API calls
# Backend uses PUBLIC_FRONTEND_URL for CORS and invite links
PUBLIC_FRONTEND_URL=https://app.example.com
PUBLIC_BACKEND_URL=https://api.example.com
